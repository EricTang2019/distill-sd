# syntax=docker/dockerfile:1.7

ARG BASE_IMAGE=verl-deltaai-base:25.05-arm64
FROM ${BASE_IMAGE}

ARG TORCH_INDEX_URL=https://download.pytorch.org/whl/cu128
ARG PYPI_INDEX_URL=https://pypi.org/simple
ARG MAX_JOBS=48

ENV MAX_JOBS=${MAX_JOBS} \
    PIP_CONSTRAINT=/opt/verl-deltaai/env.verlsd.constraints.txt

RUN python -m pip uninstall -y \
    torch torchvision torchaudio \
    numpy \
    flash-attn flash_attn \
    vllm \
    flashinfer-python \
    transformers ray triton \
    cugraph-service-server rmm pylibraft cuvs cudf dask-cuda distributed-ucxx \
    pylibcudf cuml cugraph nvidia-dali-cuda120 mdit-py-plugins thinc \
    raft-dask ucxx ucx-py dask-cudf jupytext spacy pylibcugraph \
    nx-cugraph cudf-polars \
    || true

RUN python -m pip install \
    --index-url ${TORCH_INDEX_URL} \
    --extra-index-url ${PYPI_INDEX_URL} \
    torch==2.9.1 \
    torchvision==0.24.1 \
    torchaudio==2.9.1

RUN python -m pip install \
    numpy==2.2.6 \
    pynvml==13.0.1 \
    ray==2.54.0 \
    triton==3.5.1 \
    transformers==4.57.6 \
    flashinfer-python==0.6.1 \
    vllm==0.15.1

RUN MAX_JOBS=${MAX_JOBS} python -m pip install --no-build-isolation flash-attn==2.8.3
